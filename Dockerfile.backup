FROM node:20.19-alpine

RUN apk add --no-cache \
    bash \
    coreutils \
    findutils \
    gzip \
    mariadb-client \
    tar \
    tzdata

WORKDIR /app

COPY scripts ./scripts
COPY server/services/backup.js ./server/services/backup.js
COPY server/services/maintenance-jobs.js ./server/services/maintenance-jobs.js
COPY scripts/maintenance-job-cli.js ./scripts/maintenance-job-cli.js

CMD ["bash", "scripts/backup.sh"]

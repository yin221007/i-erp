# i ERP public example configuration. Copy to .env and replace every secret before production use.
IERP_VERSION=1.10.0
IERP_COLOR=blue

DB_HOST=mysql
DB_PORT=3306
DB_USER=ierp
DB_PASSWORD=replace-with-strong-database-password
DB_NAME=ierp
DB_CONNECTION_LIMIT=10
DB_CLIENT_TLS=disabled

NAS_UID=1000
NAS_GID=1000

PUBLIC_ORIGINS=http://localhost:10666
SESSION_SECRET=replace-with-at-least-32-random-characters
MAINTENANCE_JOB_SECRET=replace-with-another-32-character-random-secret

FRONTEND_PORT=10666
UPLOADS_PATH=/srv/ierp/uploads
BACKUP_PATH=/srv/ierp/backups
DEPLOY_PATH=/srv/ierp/app
MAINTENANCE_QUEUE_PATH=/srv/ierp/maintenance-queue

BACKUP_SCHEDULE_MORNING=06:30
BACKUP_SCHEDULE_EVENING=18:30
BACKUP_POLL_SECONDS=300
UPLOAD_MAX_BYTES=104857600

DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
AI_REQUEST_TIMEOUT_MS=90000
AI_MAX_CONCURRENT_PER_USER=2

MAIL_ALLOWED_IMAP_ENDPOINTS=imap.qq.com:993,hwimap.exmail.qq.com:993
MAIL_ALLOWED_SMTP_ENDPOINTS=smtp.qq.com:465,hwsmtp.exmail.qq.com:465
MAIL_MAX_MESSAGE_BYTES=10485760

GREEN_PRODUCTION_PROJECT=deploy
GREEN_BACKEND_CONTAINER=ierp-green-backend
GREEN_FRONTEND_CONTAINER=ierp-green-frontend
GREEN_NETWORK_NAME=ierp-green-net
GREEN_FRONTEND_PORT=10667
GREEN_CLONE_PROJECT=ierp-candidate-clone
GREEN_CLONE_BACKEND_CONTAINER=ierp-clone-backend
GREEN_CLONE_FRONTEND_CONTAINER=ierp-clone-frontend
GREEN_CLONE_NETWORK_NAME=ierp-clone-net
GREEN_CLONE_NETWORK_SUBNET=192.168.96.0/24
GREEN_CLONE_FRONTEND_PORT=10668
GREEN_CLONE_MAINTENANCE_QUEUE_PATH=/srv/ierp/maintenance-queue-clone
